# ─────────────────────────────────────────────────────────
# Paystack Configuration
# ─────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.paystack.com/#/settings/developers
#
# Use test keys during development, live keys in production
# NEXT_PUBLIC_ prefix is required — this key is used in the browser

NEXT_PUBLIC_PAYSTACK_KEY=pk_test_REPLACE_WITH_YOUR_PUBLIC_KEY

# ─────────────────────────────────────────────────────────
# (Optional) Secret key — for server-side payment verification
# NEVER expose this in frontend code
# ─────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
